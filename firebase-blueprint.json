{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Private profile data for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "string" },
        "sex": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "conditions": { "type": "array", "items": { "type": "string" } },
        "familyHistory": { "type": "array", "items": { "type": "string" } },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "vaccinationStatus": { "type": "string" },
        "setupDone": { "type": "boolean" },
        "bp": { "type": "string" },
        "sugar": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "journal": {
      "title": "Journal Entry",
      "description": "Daily health log entry",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "mood": { "type": "number" },
        "sleep": { "type": "number" },
        "energy": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["date"]
    },
    "reminder": {
      "title": "Reminder",
      "properties": {
        "name": { "type": "string" },
        "dose": { "type": "string" },
        "time": { "type": "string" },
        "freq": { "type": "string" },
        "on": { "type": "boolean" }
      }
    },
    "record": {
      "title": "Medical Record",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "doctor": { "type": "string" }
      }
    },
    "family": {
      "title": "Family Member",
      "properties": {
        "name": { "type": "string" },
        "relation": { "type": "string" },
        "age": { "type": "string" },
        "score": { "type": "number" }
      }
    },
    "policy": {
      "title": "Insurance Policy",
      "properties": {
        "policyName": { "type": "string" },
        "policyNumber": { "type": "string" },
        "provider": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "appointment": {
      "title": "Appointment",
      "properties": {
        "clinicName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User private profile"
    },
    "users/{userId}/journal/{entryId}": {
      "schema": "journal",
      "description": "User's health journal entries"
    },
    "users/{userId}/reminders/{reminderId}": {
      "schema": "reminder"
    },
    "users/{userId}/records/{recordId}": {
      "schema": "record"
    },
    "users/{userId}/family/{memberId}": {
      "schema": "family"
    },
    "users/{userId}/policies/{policyId}": {
      "schema": "policy"
    },
    "users/{userId}/appointments/{apptId}": {
      "schema": "appointment"
    }
  }
}
