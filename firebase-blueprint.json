{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Private profile data for a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "string" },
        "sex": { "type": "string" },
        "city": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "bp": { "type": "string" },
        "sugar": { "type": "string" },
        "blood": { "type": "string" },
        "conditions": { "type": "array", "items": { "type": "string" } },
        "medicines": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dose": { "type": "string" },
              "dailyFrequency": { "type": "integer" },
              "totalQuantity": { "type": "integer" },
              "lastRefillDate": { "type": "string", "format": "date" }
            }
          } 
        },
        "familyHistory": { "type": "array", "items": { "type": "string" } },
        "allergies": { "type": "array", "items": { "type": "string" } },
        "vaccinationHistory": { "type": "array", "items": { "type": "string" } },
        "emergencyContactName": { "type": "string" },
        "emergencyContactPhone": { "type": "string" },
        "emergencyContactRelation": { "type": "string" },
        "company": { "type": "string" },
        "corporateId": { "type": "string" },
        "setupDone": { "type": "boolean" },
        "notificationsEnabled": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "updatedAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "journal": {
      "title": "Journal Entry",
      "description": "Daily health log entry",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "mood": { "type": "number" },
        "sleep": { "type": "number" },
        "energy": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["date"]
    },
    "reminder": {
      "title": "Reminder",
      "properties": {
        "name": { "type": "string" },
        "dose": { "type": "string" },
        "time": { "type": "string" },
        "freq": { "type": "string" },
        "on": { "type": "boolean" }
      }
    },
    "record": {
      "title": "Medical Record",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "doctor": { "type": "string" }
      }
    },
    "family": {
      "title": "Family Member",
      "properties": {
        "name": { "type": "string" },
        "relation": { "type": "string" },
        "age": { "type": "string" },
        "score": { "type": "number" }
      }
    },
    "policy": {
      "title": "Insurance Policy",
      "properties": {
        "policyName": { "type": "string" },
        "policyNumber": { "type": "string" },
        "provider": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "appointment": {
      "title": "Appointment",
      "properties": {
        "clinicName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "Trail of data access",
      "type": "object",
      "properties": {
        "resource": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string" },
        "accessedBy": { "type": "string" }
      }
    },
    "FamilyPermission": {
      "title": "Family Permission",
      "description": "Permission for family sync",
      "type": "object",
      "properties": {
        "memberId": { "type": "string" },
        "name": { "type": "string" },
        "canViewAlerts": { "type": "boolean" },
        "canViewMedications": { "type": "boolean" },
        "canViewRecords": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "users",
      "description": "User private profile"
    },
    "users/{userId}/journal/{entryId}": {
      "schema": "journal",
      "description": "User's health journal entries"
    },
    "users/{userId}/reminders/{reminderId}": {
      "schema": "reminder"
    },
    "users/{userId}/records/{recordId}": {
      "schema": "record"
    },
    "users/{userId}/family/{memberId}": {
      "schema": "family"
    },
    "users/{userId}/policies/{policyId}": {
      "schema": "policy"
    },
    "users/{userId}/appointments/{apptId}": {
      "schema": "appointment"
    },
    "users/{userId}/accessLogs/{logId}": {
      "schema": "AccessLog"
    },
    "users/{userId}/familyPermissions/{permId}": {
      "schema": "FamilyPermission"
    }
  }
}
