rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isValidAppointment(data) {
      return data.clinicId is string && data.clinicId.size() > 0 &&
             data.patientId == request.auth.uid &&
             data.date is string && data.time is string;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /appointments/{appointmentId} {
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(request.resource.data);
      allow read, update: if isSignedIn() && resource.data.patientId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.patientId == request.auth.uid;
    }
  }
}
